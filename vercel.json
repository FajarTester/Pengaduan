{
    "version": 2,
    "builds": [
        { "src": "backend/main.go", "use": "@vercel/go" },
        { "src": "frontend/**/*.php", "use": "vercel-php@0.6.0" }
    ],
    "routes": [
        { "src": "/api/(.*)", "dest": "backend/main.go" },
        { "src": "/(.*).php", "dest": "frontend/$1.php" },
        { "src": "/(.*)", "dest": "frontend/index.php" }
    ]
}
