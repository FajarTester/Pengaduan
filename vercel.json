{
    "version": 2,
    "builds": [
        {
            "src": "backend/main.go",
            "use": "@vercel/go"
        },
        {
            "src": "frontend/index.php",
            "use": "vercel-php@0.9.0"
        },
        {
            "src": "frontend/plugins/api.php",
            "use": "vercel-php@0.9.0"
        }
    ],
    "routes": [
        { "src": "/api/(.*)", "dest": "backend/main.go" },
        { "src": "/(.*)", "dest": "frontend/index.php" }
    ]
}
