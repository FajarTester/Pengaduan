{
    "version": 2,
    "builds": [
        {
            "src": "backend/main.go",
            "use": "@vercel/go"
        },
        {
            "src": "frontend/**/*.php",
            "use": "vercel-php@0.9.0"
        }
    ],
    "routes": [
        {
            "src": "/api/(.*)",
            "dest": "backend/main.go"
        },
        {
            "src": "/(.*)",
            "dest": "frontend/index.php"
        }
    ]
}
